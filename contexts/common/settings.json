{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Common Claude Code hooks for smart-claude. Loaded into every context — session memory, commit quality, safety guardrails. Language-specific format/typecheck hooks live in their own contexts (nestjs/frontend for JS/TS, fastapi for Python).",
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",

      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/secrets/**)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.ppk)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.kdbx)",
      "Read(**/*.gpg)",
      "Read(**/id_rsa*)",
      "Read(**/id_dsa*)",
      "Read(**/id_ecdsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.gcp/**)",
      "Read(**/.azure/**)",
      "Read(**/.kube/**)",
      "Read(**/kubeconfig*)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Read(**/.my.cnf)",
      "Read(**/.htpasswd)",
      "Read(**/service-account*.json)",
      "Read(**/service_account*.json)",

      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",

      "Bash(cat *.env*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat */.ssh/*)",
      "Bash(cat */.aws/*)",
      "Bash(cat */credentials*)",
      "Bash(less *.env*)",
      "Bash(more *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(source *.env*)",
      "Bash(. *.env*)",
      "Bash(printenv)",
      "Bash(env)",
      "Bash(xxd *.env*)",
      "Bash(base64 *.env*)",
      "Bash(strings *.env*)",
      "Bash(cp *.env* *)",
      "Bash(mv *.env* *)",
      "Bash(tar *.env*)",
      "Bash(zip *.env*)",
      "Bash(scp *.env*)",
      "Bash(curl *-T *.env*)",
      "Bash(rsync *.env*)",
      "Bash(awk *.env*)",
      "Bash(sed *.env*)",
      "Bash(grep *.env*)",
      "Bash(rg *.env*)",
      "Bash(python -c *open*.env*)",
      "Bash(python3 -c *open*.env*)",
      "Bash(node -e *readFile*.env*)",
      "Bash(node -e *.env*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/session-start.js\""
          }
        ],
        "description": "Load previous session context at startup"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/library-docs-reminder.js\"",
            "timeout": 5000
          }
        ],
        "description": "When prompt mentions libraries/packages/SDKs/frameworks/system design, inject reminder to fetch docs via context7 or exa MCP before coding"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/secrets-guard.js\"",
            "timeout": 5000
          }
        ],
        "description": "Block access to secret files (.env, .pem, .ssh/*, .aws/*, kubeconfig, ...) via any tool — absolute paths, Bash tricks, or obscure shells"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); CMD=$(echo \"$INPUT\" | node -pe \"JSON.parse(require(\\\"fs\\\").readFileSync(0,\\\"utf8\\\")).tool_input.command || \\\"\\\"\" 2>/dev/null || echo \"\"); if echo \"$CMD\" | grep -qE \"git\\s+(push|commit).*--no-verify\"; then echo \"BLOCK: Do not bypass git hooks with --no-verify.\" >&2; exit 2; fi'"
          }
        ],
        "description": "Block git operations that bypass hooks (--no-verify)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); CMD=$(echo \"$INPUT\" | node -pe \"JSON.parse(require(\\\"fs\\\").readFileSync(0,\\\"utf8\\\")).tool_input.command || \\\"\\\"\" 2>/dev/null || echo \"\"); if echo \"$CMD\" | grep -qE \"(npm|pnpm|yarn|bun)\\s+(run\\s+)?(dev|start|build|test|serve)\" || echo \"$CMD\" | grep -qE \"(pytest|cargo|go\\s+test)\"; then if [ -z \"$TMUX\" ] && [ -z \"$TERM_PROGRAM\" ]; then echo \"[Hook] Consider running in tmux for session persistence: tmux new -s dev\" >&2; fi; fi'"
          }
        ],
        "description": "Reminder to use tmux for long-running dev commands"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/commit-quality.js\"",
            "timeout": 30000
          }
        ],
        "description": "Pre-commit quality gate: secrets block, console.log warn, conventional commit check"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/install-guard.js\"",
            "timeout": 5000
          }
        ],
        "description": "Warn on package install commands without the dependency-approval workflow (rules/common/dependency-approval.md)"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/config-protection.js\""
          }
        ],
        "description": "Block writes to linter/formatter config files — fix the code, not the config"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/doc-file-warning.js\""
          }
        ],
        "description": "Warn on ad-hoc doc filenames (NOTES, TODO, SCRATCH, etc.) outside structured dirs"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/suggest-compact.js\"",
            "timeout": 5000,
            "async": true
          }
        ],
        "description": "Suggest strategic /compact at logical intervals (every COMPACT_THRESHOLD tool calls)"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/pre-compact.js\""
          }
        ],
        "description": "Save compaction marker to active session file before context is summarized"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"[Session] Remember to commit your work and run tests before ending.\" >&2'",
            "timeout": 5000
          }
        ],
        "description": "Session end reminder to commit and test"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/session-end.js\"",
            "async": true,
            "timeout": 30000
          }
        ],
        "description": "Persist session summary to <project>/.claude/.storage/session-data/ after each response"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/scripts/hooks/evaluate-session.js\"",
            "async": true,
            "timeout": 10000
          }
        ],
        "description": "Signal pattern extraction for sessions with 10+ messages"
      }
    ]
  }
}